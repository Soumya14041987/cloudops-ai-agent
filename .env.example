# ─────────────────────────────────────────────────────────────────────────────
# CloudOps AI Agent — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Core ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default                          # local dev only; not used in Lambda

# ── Amazon Bedrock ────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ── Agent Behaviour ───────────────────────────────────────────────────────────
# Set AUTO_EXECUTE=true to let the agent call AWS APIs for LOW-risk fixes.
AUTO_EXECUTE=false

# Set DRY_RUN=false only in production when AUTO_EXECUTE=true.
DRY_RUN=true

# Maximum lookback window for logs/metrics queries (minutes).
MAX_LOG_LOOKBACK=240

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR

# ── Lambda Deployment (used by scripts/deploy.sh) ────────────────────────────
LAMBDA_FUNCTION_NAME=cloudops-ai-agent
LAMBDA_ROLE_ARN=arn:aws:iam::123456789012:role/cloudops-ai-agent-role
LAMBDA_MEMORY_MB=512
LAMBDA_TIMEOUT_SECONDS=300

# ── Notifications (optional — used by remediation agent) ─────────────────────
# PAGERDUTY_ROUTING_KEY=your_pagerduty_routing_key
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
